---
/**
 * Floating "back to top" button — appears once the page has scrolled past
 * roughly one viewport height, smooth-scrolls to top on click. Included
 * globally in BaseLayout so it's available on both the home page and long
 * project-detail articles.
 */
---

<button type="button" class="back-to-top" id="back-to-top" aria-label="Back to top">
  ↑
</button>

<script>
  const button = document.getElementById('back-to-top');
  if (button) {
    const toggle = () => {
      button.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.6);
    };
    toggle();
    window.addEventListener('scroll', toggle, { passive: true });
    button.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style>
  .back-to-top {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 40;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1px solid var(--border-soft);
    background: var(--accent);
    color: #fff;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    /* lifted look (item 7): a soft drop shadow so it floats above the page */
    box-shadow:
      0 6px 16px -2px color-mix(in srgb, var(--accent) 55%, transparent),
      0 10px 28px -6px rgba(0, 0, 0, 0.35);
    transform: translateY(0.5rem);
    transition: opacity 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .back-to-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: none;
  }
  .back-to-top:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow:
      0 10px 22px -2px color-mix(in srgb, var(--accent) 60%, transparent),
      0 16px 36px -6px rgba(0, 0, 0, 0.4);
  }
  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: none;
    }
  }
</style>
