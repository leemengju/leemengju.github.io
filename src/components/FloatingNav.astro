---
/**
 * Section navigation with scrollspy (IntersectionObserver highlights the
 * section currently in view). Generic over `items` so it serves both the
 * home page (About/Skills/...) and project articles (per-heading TOC).
 *
 * Two responsive layouts from one markup:
 *  - ≥1160px: fixed right-edge dot rail; labels fly out to the left on hover.
 *  - <1160px: sticky top chip bar (horizontally scrollable) — the mobile
 *    "top menu" collapse. The element is rendered in-flow at the top of the
 *    content so position:sticky works.
 */
interface NavItem {
  id: string;
  label: string;
}
interface Props {
  items: NavItem[];
}
const { items } = Astro.props as Props;
---

<nav class="floating-nav" aria-label="Section navigation">
  <ul>
    {
      items.map((item) => (
        <li>
          <a href={`#${item.id}`} data-nav-link={item.id}>
            <span class="floating-nav__dot" />
            <span class="floating-nav__label">{item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  const links = document.querySelectorAll('[data-nav-link]');
  if (links.length > 0) {
    const sections = Array.from(links)
      .map((link) => document.getElementById(link.getAttribute('data-nav-link') || ''))
      .filter((el): el is HTMLElement => el !== null);

    const setActive = (id: string) => {
      links.forEach((link) => {
        const active = link.getAttribute('data-nav-link') === id;
        link.classList.toggle('is-active', active);
        // Keep the active chip in view when the bar is in horizontal mode.
        if (active && window.matchMedia('(max-width: 1160px)').matches) {
          link.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) setActive(visible.target.id);
      },
      { rootMargin: '-35% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] }
    );
    sections.forEach((el) => observer.observe(el));
  }
</script>

<style>
  /* ---------- Desktop (≥1161px): fixed right dot rail ---------- */
  .floating-nav {
    position: fixed;
    right: 1.4rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
  }
  .floating-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .floating-nav a {
    position: relative;
    display: block;
    padding: 0.25rem;
    text-decoration: none;
    color: inherit;
  }
  .floating-nav__dot {
    display: block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: color-mix(in srgb, currentColor 30%, transparent);
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .floating-nav a:hover .floating-nav__dot {
    background: color-mix(in srgb, currentColor 60%, transparent);
  }
  .floating-nav a.is-active .floating-nav__dot {
    background: var(--accent);
    transform: scale(1.5);
  }
  .floating-nav__label {
    position: absolute;
    right: calc(100% + 0.6rem);
    top: 50%;
    transform: translateY(-50%) translateX(0.25rem);
    white-space: nowrap;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    box-shadow: var(--shadow);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .floating-nav a:hover .floating-nav__label,
  .floating-nav a.is-active .floating-nav__label {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-nav__dot,
    .floating-nav__label {
      transition: none;
    }
  }

  /* ---------- ≤1160px: sticky top chip bar ---------- */
  @media (max-width: 1160px) {
    .floating-nav {
      position: sticky;
      top: 0;
      right: auto;
      transform: none;
      margin: 0 -1.5rem 0.5rem;
      padding: 0.5rem 1.5rem;
      background: color-mix(in srgb, var(--page-bg) 88%, transparent);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border-soft);
    }
    .floating-nav ul {
      display: flex;
      gap: 0.4rem;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .floating-nav ul::-webkit-scrollbar {
      display: none;
    }
    .floating-nav a {
      display: inline-block;
      padding: 0.3rem 0.85rem;
      border-radius: 999px;
      border: 1px solid var(--border-soft);
      background: var(--fill-softer);
      white-space: nowrap;
    }
    .floating-nav__dot {
      display: none;
    }
    .floating-nav__label {
      position: static;
      transform: none;
      opacity: 1;
      pointer-events: auto;
      padding: 0;
      border: none;
      background: none;
      box-shadow: none;
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .floating-nav a.is-active {
      background: var(--accent);
      border-color: var(--accent);
    }
    .floating-nav a.is-active .floating-nav__label {
      color: #fff;
    }
  }
</style>
