---
/**
 * One listing card, shared by the zh and en home pages. Text-only by design
 * (no cover image): the generated art duplicated the title, so the card is
 * now title + role/period + headline metric + tags. `data-categories` feeds
 * the home page's filter pills; a cursor-tracked 3D tilt adds life.
 */
import TagRow from './TagRow.astro';
import type { ProjectEntry } from '../lib/projects';
import { projectPath, type Locale } from '../lib/i18n';

interface Props {
  project: ProjectEntry;
  locale?: Locale;
}
const { project, locale = 'zh' } = Astro.props as Props;
const categories = (project.data.categories ?? []).join(' ');
---

<li class="project-card" data-reveal data-categories={categories}>
  <a href={projectPath(project.id, locale)}>
    <div class="project-card__body">
      <span class="project-card__title">{project.data.title}</span>
      <span class="project-card__meta">{project.data.role} · {project.data.period}</span>
      {project.data.metrics && <span class="project-card__metrics">{project.data.metrics}</span>}
      <TagRow tags={project.data.tags} />
    </div>
    <span class="project-card__arrow" aria-hidden="true">↗</span>
  </a>
</li>

<style>
  .project-card {
    height: 100%;
    transition: transform 0.25s ease;
  }
  .project-card:hover {
    transform: translateY(-4px);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card:hover {
      transform: none;
    }
  }
  .project-card a {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem 1.6rem;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow);
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
    overflow: hidden;
  }
  /* faint accent wash that grows from the corner on hover — replaces the cover */
  .project-card a::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 90% at 100% 0%, var(--accent-soft), transparent 55%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .project-card:hover a {
    box-shadow: var(--shadow-hover);
    border-color: var(--border-strong);
  }
  .project-card:hover a::before {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card a::before {
      transition: none;
    }
  }
  .project-card__body {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .project-card__title {
    display: block;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.4;
    padding-right: 1.5rem;
  }
  .project-card__meta {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 0.4rem;
  }
  .project-card__metrics {
    display: block;
    margin-top: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    font-size: 0.95rem;
  }
  .project-card :global(.tag-row) {
    margin-top: auto;
    padding-top: 1rem;
  }
  .project-card__arrow {
    position: absolute;
    top: 1.4rem;
    right: 1.5rem;
    font-size: 1rem;
    color: var(--text-muted);
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .project-card:hover .project-card__arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
</style>
