---
/**
 * Full project-detail article (header + rendered markdown body), shared by
 * the zh and en [slug] pages so the two locales can't drift apart. Locale
 * only affects UI strings and the back-link target — all content comes from
 * the (already locale-specific) collection entry.
 */
import { render } from 'astro:content';
import MetricCard from './MetricCard.astro';
import TagRow from './TagRow.astro';
import BeforeAfterBar from './BeforeAfterBar.astro';
import Timeline from './Timeline.astro';
import FloatingNav from './FloatingNav.astro';
import type { ProjectEntry } from '../lib/projects';
import { strings, homePath, type Locale } from '../lib/i18n';

interface Props {
  project: ProjectEntry;
  locale?: Locale;
}
const { project, locale = 'zh' } = Astro.props as Props;
const t = strings[locale];
const { Content, headings } = await render(project);

// Per-article TOC for the floating nav: the markdown's ## sections.
const tocItems = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, label: h.text }));
---

{tocItems.length > 1 && <FloatingNav items={tocItems} />}

<a class="back-link" href={homePath(locale)}>{t.backToHome}</a>

<header class="project-header">
  <h1>{project.data.title}</h1>
  <p class="project-header__meta">
    {project.data.role} · {project.data.period}
  </p>
  {project.data.metrics && <MetricCard metric={project.data.metrics} />}
  <TagRow tags={project.data.tags} />
  {
    project.data.beforeAfter && (
      <BeforeAfterBar
        before={project.data.beforeAfter.before}
        after={project.data.beforeAfter.after}
        unit={project.data.beforeAfter.unit}
        label={project.data.beforeAfter.label}
        motion={project.data.beforeAfterMotion}
      />
    )
  }
  {project.data.timeline && <Timeline items={project.data.timeline} />}
  {
    project.data.github && (
      <a class="github-link" href={project.data.github} target="_blank" rel="noopener noreferrer">
        {t.viewOnGitHub}
      </a>
    )
  }
</header>

<article class="project-body">
  <Content />
</article>

<style>
  .back-link {
    display: inline-block;
    margin: 1.5rem 0 1rem;
    color: inherit;
    opacity: 0.7;
    text-decoration: none;
  }
  .back-link:hover {
    opacity: 1;
  }
  .project-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 2rem;
  }
  .project-header__meta {
    opacity: 0.7;
    margin-top: 0.25rem;
  }
  .project-header :global(.metric-card) {
    margin-top: 0.75rem;
  }
  .project-header :global(.tag-row) {
    margin-top: 0.75rem;
  }
  .github-link {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    border: 1px solid currentColor;
    border-radius: 0.5rem;
    padding: 0.4rem 0.9rem;
  }
  .project-body :global(h2) {
    margin-top: 2rem;
    color: var(--accent);
    /* keep anchor targets clear of the sticky chip bar on <1160px layouts */
    scroll-margin-top: 4rem;
  }
  .project-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.92rem;
  }
  .project-body :global(th),
  .project-body :global(td) {
    border: 1px solid var(--border-soft);
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }
  .project-body :global(th) {
    background: var(--fill-softer);
    font-weight: 600;
  }
  .project-body :global(tr:nth-child(even) td) {
    background: var(--fill-softer);
  }

  /* ---- Legacy design-project media (item 14): responsive layout ---- *
   * Shared look: rounded, layered Aceternity-style shadow, subtle border.
   * Single images and each cell of a .media-grid share the treatment;
   * sizing/columns change across the three requested breakpoints. */
  .project-body :global(img),
  .project-body :global(.media-grid img),
  .project-body :global(video) {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
    border: 1px solid var(--border-soft);
    box-shadow:
      0 0 0 1px rgba(34, 42, 53, 0.04),
      0 4px 8px rgba(34, 42, 53, 0.06),
      0 16px 48px -12px rgba(47, 48, 55, 0.12);
  }
  .project-body :global(video) {
    width: 100%;
  }
  /* standalone image: block flow, spaced */
  .project-body :global(p) :global(img) {
    margin: 1.5rem auto;
  }
  /* gallery grid built by rehype-media-grid.mjs */
  .project-body :global(.media-grid) {
    display: grid;
    gap: 1rem;
    margin: 1.75rem 0;
    grid-template-columns: 1fr;
  }
  .project-body :global(.media-grid img) {
    margin: 0;
    width: 100%;
    object-fit: cover;
  }

  /* Mobile (≤400px): single column, full-bleed within content padding. */
  @media (max-width: 400px) {
    .project-body :global(.media-grid) {
      gap: 0.75rem;
    }
  }

  /* Tablet / small laptop (401–1279px): grids go 2-up. */
  @media (min-width: 401px) {
    .project-body :global(.media-grid) {
      grid-template-columns: repeat(2, 1fr);
    }
    /* a 3-image run reads better as 3-up here */
    .project-body :global(.media-grid[data-count='3']) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Desktop (1280–1440px): comfortable reading width; standalone images
     centered at a medium max, grids stay 2-up with a touch more gap. */
  @media (min-width: 1280px) and (max-width: 1440px) {
    .project-body :global(p) :global(img) {
      max-width: 820px;
    }
    .project-body :global(.media-grid) {
      gap: 1.25rem;
    }
  }

  /* Large (≥1441px, up to 1920): larger standalone images, roomier grid. */
  @media (min-width: 1441px) {
    .project-body :global(p) :global(img) {
      max-width: 1040px;
    }
    .project-body :global(.media-grid) {
      gap: 1.5rem;
    }
  }
</style>
