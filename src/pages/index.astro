---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeSections from '../components/HomeSections.astro';
import { getSortedProjects } from '../lib/projects';
import { strings } from '../lib/i18n';
import '../styles/stats-band.css';

const projects = await getSortedProjects('zh');
---

<BaseLayout title={strings.zh.siteTitle}>
  <HomeSections locale="zh" projects={projects} />
</BaseLayout>
