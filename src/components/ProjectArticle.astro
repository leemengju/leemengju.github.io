---
/**
 * Full project-detail article (header + rendered markdown body), shared by
 * the zh and en [slug] pages so the two locales can't drift apart. Locale
 * only affects UI strings and the back-link target — all content comes from
 * the (already locale-specific) collection entry.
 */
import { render } from 'astro:content';
import MetricCard from './MetricCard.astro';
import TagRow from './TagRow.astro';
import BeforeAfterBar from './BeforeAfterBar.astro';
import Timeline from './Timeline.astro';
import type { ProjectEntry } from '../lib/projects';
import { strings, homePath, type Locale } from '../lib/i18n';

interface Props {
  project: ProjectEntry;
  locale?: Locale;
}
const { project, locale = 'zh' } = Astro.props as Props;
const t = strings[locale];
const { Content } = await render(project);
---

<a class="back-link" href={homePath(locale)}>{t.backToHome}</a>

<header class="project-header">
  <h1>{project.data.title}</h1>
  <p class="project-header__meta">
    {project.data.role} · {project.data.period}
  </p>
  {project.data.metrics && <MetricCard metric={project.data.metrics} />}
  <TagRow tags={project.data.tags} />
  {
    project.data.beforeAfter && (
      <BeforeAfterBar
        before={project.data.beforeAfter.before}
        after={project.data.beforeAfter.after}
        unit={project.data.beforeAfter.unit}
        label={project.data.beforeAfter.label}
        motion={project.data.beforeAfterMotion}
      />
    )
  }
  {project.data.timeline && <Timeline items={project.data.timeline} />}
  {
    project.data.github && (
      <a class="github-link" href={project.data.github} target="_blank" rel="noopener noreferrer">
        {t.viewOnGitHub}
      </a>
    )
  }
</header>

<article class="project-body">
  <Content />
</article>

<style>
  .back-link {
    display: inline-block;
    margin: 1.5rem 0 1rem;
    color: inherit;
    opacity: 0.7;
    text-decoration: none;
  }
  .back-link:hover {
    opacity: 1;
  }
  .project-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 2rem;
  }
  .project-header__meta {
    opacity: 0.7;
    margin-top: 0.25rem;
  }
  .project-header :global(.metric-card) {
    margin-top: 0.75rem;
  }
  .project-header :global(.tag-row) {
    margin-top: 0.75rem;
  }
  .github-link {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    border: 1px solid currentColor;
    border-radius: 0.5rem;
    padding: 0.4rem 0.9rem;
  }
  .project-body :global(h2) {
    margin-top: 2rem;
  }
  .project-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.92rem;
  }
  .project-body :global(th),
  .project-body :global(td) {
    border: 1px solid var(--border-soft);
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }
  .project-body :global(th) {
    background: var(--fill-softer);
    font-weight: 600;
  }
  .project-body :global(tr:nth-child(even) td) {
    background: var(--fill-softer);
  }
</style>
