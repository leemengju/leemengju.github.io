---
import '../styles/tokens.css';
import '../styles/code-blocks.css';
import DiagramBlock from '../components/DiagramBlock.astro';
import RevealScript from '../components/RevealScript.astro';
import BackToTop from '../components/BackToTop.astro';
import ThemeVariantSwitch from '../components/ThemeVariantSwitch.astro';
import { strings, localeFromPath, alternatePath, homePath } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props as Props;

// Locale is derived from the URL (en pages live under /en/), so pages don't
// have to thread a locale prop through the layout. Slugs are identical across
// locales, making the language switcher a pure path transform.
const locale = localeFromPath(Astro.url.pathname);
const t = strings[locale];
const altPath = alternatePath(Astro.url.pathname);
const altLangAttr = strings[locale === 'en' ? 'zh' : 'en'].langAttr;
---

<html lang={t.langAttr}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    {/* "Oi" display face — used for the stat-card numbers (items 5/6) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oi&display=swap" rel="stylesheet" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}
    <link rel="alternate" hreflang={t.langAttr} href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="alternate" hreflang={altLangAttr} href={new URL(altPath, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(locale === 'en' ? altPath : Astro.url.pathname, Astro.site)} />
  </head>
  <body>
    <header class="site-header">
      <a class="site-header__brand" href={homePath(locale)}>
        <span class="site-header__logo" aria-hidden="true"></span>
        <span>{t.brand}</span>
      </a>
      <div class="site-header__actions">
        <ThemeVariantSwitch />
        <a class="site-header__lang" href={altPath} aria-label={t.switcherAria}>{t.switcherLabel}</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">© LanceLee Portfolio. All rights reserved.</footer>
    <RevealScript />
    <DiagramBlock />
    <BackToTop />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
  }
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
  }
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: inherit;
  }
  /* logo is a masked silhouette so it takes the brand color exactly
     (white in Dark, accent in Bright) — see ThemeVariantSwitch */
  .site-header__logo {
    display: block;
    width: 1.75rem;
    height: 1.75rem;
    background-color: currentColor;
    -webkit-mask: url('/logo.svg') center / contain no-repeat;
    mask: url('/logo.svg') center / contain no-repeat;
  }
  /* language switch + theme switch cluster; fixed 20px gap on desktop */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  /* header entrance motion (item 2) — animate the brand + lang link (never the
     mobile fixed theme switch, whose fixed positioning a transformed ancestor
     would break) */
  .site-header__brand {
    animation: header-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .site-header__lang {
    animation: header-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.08s both;
  }
  @keyframes header-in {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-header__brand,
    .site-header__lang {
      animation: none;
    }
  }
  .site-header__lang {
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    opacity: 0.75;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }
  .site-header__lang:hover {
    opacity: 1;
    background: var(--fill-soft);
    border-color: var(--border-strong);
  }
  /* On narrow screens the FloatingNav hamburger is fixed at the top-right and
     was covering the language switch — pad the header so the switch sits to
     its left and stays visible/tappable (A1). */
  @media (max-width: 1160px) {
    .site-header {
      padding-right: 4.25rem;
    }
  }
  main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }
  /* Copyright footer (item 18) */
  .site-footer {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 1.75rem 1.5rem 2.5rem;
    border-top: 1px solid var(--border-soft);
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Shared card surface used by project/skill/stat cards + article header. */
  .card,
  .u-card {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  /* Motion tier L0: default reveal-on-scroll, no framework (src script below). */
  [data-reveal] {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
