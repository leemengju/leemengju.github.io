---
/**
 * ThemeVariantSwitch — Bright / Dark comparison toggle (default Dark).
 * Rendered in the site header (BaseLayout) so it appears on every page,
 * including project pages. The choice persists in localStorage['home-variant']
 * and the inline script applies it during parse to avoid a flash. The palettes
 * themselves live in tokens.css (:root[data-variant='bright'|'dark']).
 */
---

<div class="variant-switch" role="group" aria-label="Theme">
  <button type="button" data-variant-set="bright">Bright</button>
  <button type="button" data-variant-set="dark" class="is-active">Dark</button>
</div>

<script is:inline>
  (function () {
    var KEY = 'home-variant';
    var root = document.documentElement;
    var apply = function (v) {
      if (v !== 'bright' && v !== 'dark') v = 'dark';
      root.setAttribute('data-variant', v);
      var btns = document.querySelectorAll('.variant-switch button');
      for (var i = 0; i < btns.length; i++) {
        btns[i].classList.toggle('is-active', btns[i].getAttribute('data-variant-set') === v);
      }
    };
    var saved;
    try { saved = localStorage.getItem(KEY); } catch (e) { saved = null; }
    apply(saved || 'dark');
    document.addEventListener('click', function (e) {
      var b = e.target && e.target.closest ? e.target.closest('.variant-switch button') : null;
      if (!b) return;
      var v = b.getAttribute('data-variant-set');
      try { localStorage.setItem(KEY, v); } catch (e2) {}
      apply(v);
    });
  })();
</script>

<style is:global>
  /* Desktop/tablet: the switch sits in the header actions row (20px gap from
     the language switch, set on .site-header__actions). */
  .variant-switch {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    background: var(--fill-softer);
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    font-size: 0.72rem;
  }
  .variant-switch button {
    font: inherit;
    font-weight: 600;
    border: none;
    background: transparent;
    color: var(--text-muted);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .variant-switch button:hover {
    color: var(--text);
  }
  .variant-switch button.is-active {
    color: #fff;
    background: var(--accent);
  }
  .variant-switch button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Brand (masked logo + name) takes the theme's brand color: white in Dark so
     it reads on the navy, accent in Bright (item 1). */
  :root[data-variant='dark'] .site-header__brand {
    color: #ffffff;
  }
  :root[data-variant='bright'] .site-header__brand {
    color: var(--accent);
  }

  /* Mobile: the header top-right holds the language switch (and the nav
     hamburger), so drop the comparison switch to the free bottom-left corner —
     the user confirmed this placement. */
  @media (max-width: 1160px) {
    .variant-switch {
      position: fixed;
      bottom: 1rem;
      left: 1rem;
      z-index: 60;
      background: color-mix(in srgb, var(--surface) 88%, transparent);
      backdrop-filter: blur(8px);
      box-shadow: var(--shadow);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .variant-switch button {
      transition: none;
    }
  }
</style>
