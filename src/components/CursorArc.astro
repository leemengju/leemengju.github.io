---
/**
 * Framer-style cursor companion: an accent arc that trails the pointer,
 * offset to the pointer's top-right, easing toward it each frame (lerp).
 * It spins slowly all the time and swells slightly while the pointer moves.
 * Pointer-events: none, so it never intercepts clicks. Skipped entirely on
 * touch devices and under prefers-reduced-motion.
 */
---

<div class="cursor-arc" id="cursor-arc" aria-hidden="true">
  <svg viewBox="0 0 40 40" fill="none">
    <circle
      cx="20"
      cy="20"
      r="16"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-dasharray="62 39"></circle>
  </svg>
</div>

<script>
  const el = document.getElementById('cursor-arc');
  const fine = window.matchMedia('(pointer: fine)').matches;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (el && fine && !reduced) {
    let targetX = -100;
    let targetY = -100;
    let x = targetX;
    let y = targetY;
    let lastMove = 0;

    window.addEventListener(
      'mousemove',
      (e) => {
        // sit at the pointer's top-right
        targetX = e.clientX + 18;
        targetY = e.clientY - 26;
        lastMove = performance.now();
        el.classList.add('is-on');
      },
      { passive: true }
    );

    const tick = () => {
      x += (targetX - x) * 0.14;
      y += (targetY - y) * 0.14;
      const moving = performance.now() - lastMove < 120;
      el.style.transform = `translate(${x}px, ${y}px) scale(${moving ? 1.15 : 1})`;
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  } else if (el) {
    el.remove();
  }
</script>

<style>
  .cursor-arc {
    position: fixed;
    top: 0;
    left: 0;
    width: 28px;
    height: 28px;
    z-index: 90;
    pointer-events: none;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.4s ease;
    will-change: transform;
  }
  .cursor-arc.is-on {
    opacity: 0.85;
  }
  .cursor-arc svg {
    width: 100%;
    height: 100%;
    animation: cursor-arc-spin 5s linear infinite;
  }
  @keyframes cursor-arc-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
