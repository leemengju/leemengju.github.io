---
/**
 * The full home-page structure carried over from the old Framer site:
 * Hero → About(+stats carousel) → Skills → Experience → Projects(+filter) →
 * Education → Contact. Shared by the zh (/) and en (/en/) home pages so the
 * two locales stay structurally identical; only content differs.
 */
import ProjectCard from './ProjectCard.astro';
import StatsBand from './StatsBand.tsx';
import FloatingNav from './FloatingNav.astro';
import KineticGrid from './effects/KineticGrid.tsx';
import LetterSwapTitle from './effects/LetterSwapTitle.tsx';
import SmokyText from './effects/SmokyText.tsx';
import MeshTextHeading from './effects/MeshTextHeading.tsx';
import ThemeVariantSwitch from './ThemeVariantSwitch.astro';
import { strings, categoryLabels, type Locale } from '../lib/i18n';
import { getProfile } from '../lib/profile';
import type { ProjectEntry } from '../lib/projects';

interface Props {
  locale: Locale;
  projects: ProjectEntry[];
}
const { locale, projects } = Astro.props as Props;
const t = strings[locale];
const p = getProfile(locale);

const navItems = [
  { id: 'about', label: t.aboutHeading },
  { id: 'skills', label: t.skillsHeading },
  { id: 'experience', label: t.experienceHeading },
  { id: 'projects', label: t.projectsHeading },
  { id: 'education', label: t.educationHeading },
  { id: 'contact', label: t.contactHeading }
];

// Filter pills: only categories actually used by at least one project.
const usedCategories = Object.keys(categoryLabels).filter((key) =>
  projects.some((project) => (project.data.categories ?? []).includes(key))
);

// Inline stroke icons for skill cards (24×24, stroke = currentColor). Hover
// styling (accent stroke + soft fill) lives in CSS below.
const skillIcons: Record<string, string> = {
  refactor:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/><path d="M6.5 10v4a2 2 0 0 0 2 2H14"/></svg>',
  database:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v14c0 1.66 3.58 3 8 3s8-1.34 8-3V5"/><path d="M4 12c0 1.66 3.58 3 8 3s8-1.34 8-3"/></svg>',
  chart:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><rect x="7" y="12" width="3" height="6" rx="0.8"/><rect x="12" y="8" width="3" height="10" rx="0.8"/><rect x="17" y="5" width="3" height="13" rx="0.8"/></svg>',
  plug:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 7V3M15 7V3"/><path d="M7 7h10v4a5 5 0 0 1-5 5 5 5 0 0 1-5-5V7Z"/><path d="M12 16v5"/></svg>',
  stack:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3 9 5-9 5-9-5 9-5Z"/><path d="m3 13 9 5 9-5"/><path d="m3 17.5 9 5 9-5"/></svg>',
  kanban:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 7v10M12.5 7v6M17 7v8"/></svg>'
};

const githubIcon =
  '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.12 3.05.74.81 1.18 1.83 1.18 3.09 0 4.41-2.69 5.38-5.25 5.66.41.35.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.2.67.8.55A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>';
const linkedinIcon =
  '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.55V9h3.57v11.45Z"/></svg>';
---

<ThemeVariantSwitch />

<FloatingNav items={navItems} />

<section class="hero">
  <KineticGrid client:visible />
  <h1><MeshTextHeading client:visible text={t.introHeading} /></h1>
  <p class="hero__tagline">{t.introText}</p>
  <div class="hero__cta">
    {
      p.contact.resume && (
        <a class="btn btn--primary" href={p.contact.resume} target="_blank" rel="noopener noreferrer">
          {t.resumeButton}
        </a>
      )
    }
    <a class="btn btn--icon" href={p.contact.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <Fragment set:html={githubIcon} />
    </a>
    {
      p.contact.linkedin && (
        <a class="btn btn--icon" href={p.contact.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <Fragment set:html={linkedinIcon} />
        </a>
      )
    }
  </div>
</section>

<section id="about" class="section">
  <h2><LetterSwapTitle client:visible text={t.aboutHeading} /></h2>
  {p.about.map((para) => <p class="about__para" data-reveal>{para}</p>)}
  <StatsBand stats={p.stats} client:visible />
</section>

<section id="skills" class="section">
  <h2><LetterSwapTitle client:visible text={t.skillsHeading} /></h2>
  <ul class="skills">
    {
      p.skills.map((s) => (
        <li class="skill" data-reveal>
          <span class="skill__icon" aria-hidden="true">
            <Fragment set:html={skillIcons[s.icon]} />
          </span>
          <span class="skill__name">{s.name}</span>
          <span class="skill__desc">{s.desc}</span>
        </li>
      ))
    }
  </ul>
</section>

<section id="experience" class="section">
  <h2><LetterSwapTitle client:visible text={t.experienceHeading} /></h2>
  <ol class="exp">
    {
      p.experience.map((e) => (
        <li class="exp__item" data-reveal>
          <div class="exp__head">
            <span class="exp__role">{e.role}</span>
            <span class="exp__period">{e.period}</span>
          </div>
          <div class="exp__org">{e.org}</div>
          {e.summary && <p class="exp__summary">{e.summary}</p>}
          <ul class="exp__highlights">
            {e.highlights.map((h) => <li>{h}</li>)}
          </ul>
        </li>
      ))
    }
  </ol>
</section>

<section id="projects" class="section">
  <h2><LetterSwapTitle client:visible text={t.projectsHeading} /></h2>
  <div class="projects-toolbar">
    <div class="filter" role="group">
      <button class="filter__pill is-active" data-filter="all" type="button">{t.filterAll}</button>
      {
        usedCategories.map((key) => (
          <button class="filter__pill" data-filter={key} type="button">
            {categoryLabels[key][locale]}
          </button>
        ))
      }
    </div>
    <div class="view-toggle" role="group" aria-label={locale === 'en' ? 'View mode' : '檢視方式'}>
      <button type="button" data-view="list" class="is-active" aria-pressed="true" aria-label={locale === 'en' ? 'List view' : '清單檢視'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="8" y1="6" x2="20" y2="6" /><line x1="8" y1="12" x2="20" y2="12" /><line x1="8" y1="18" x2="20" y2="18" />
          <circle cx="4" cy="6" r="1" /><circle cx="4" cy="12" r="1" /><circle cx="4" cy="18" r="1" />
        </svg>
      </button>
      <button type="button" data-view="card" aria-pressed="false" aria-label={locale === 'en' ? 'Card view' : '卡片檢視'}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" />
          <rect x="3" y="14" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" />
        </svg>
      </button>
    </div>
  </div>
  <ul class="project-list is-list" data-page-size="6">
    {projects.map((project) => <ProjectCard project={project} locale={locale} />)}
  </ul>
  <div class="projects-more" hidden>
    <button class="btn-more" type="button">{locale === 'en' ? 'More projects' : '更多專案'}</button>
  </div>
  <nav class="projects-pager" aria-label={locale === 'en' ? 'Pagination' : '分頁'} hidden></nav>
</section>

<section id="education" class="section">
  <h2><LetterSwapTitle client:visible text={t.educationHeading} /></h2>
  <ol class="edu">
    {
      p.education.map((e) => (
        <li class="edu__item" data-reveal>
          <div class="exp__head">
            <span class="exp__role">
              {e.school} — {e.degree}
            </span>
            <span class="exp__period">{e.period}</span>
          </div>
          <ul class="exp__highlights">
            {e.notes.map((n) => <li>{n}</li>)}
          </ul>
        </li>
      ))
    }
  </ol>
</section>

<section id="contact" class="section">
  <h2><LetterSwapTitle client:visible text={t.contactHeading} /></h2>
  <ul class="contact">
    <li><span class="contact__k">{t.contactEmail}</span><a href={`mailto:${p.contact.email}`}><SmokyText client:visible text={p.contact.email} colorVar="var(--text)" intensity={11} /></a></li>
    <li><span class="contact__k">{t.contactGitHub}</span><a href={p.contact.github} target="_blank" rel="noopener noreferrer"><SmokyText client:visible text={p.contact.github.replace('https://', '')} colorVar="var(--text)" intensity={11} /></a></li>
    <li><span class="contact__k">{t.contactLocation}</span><SmokyText client:visible text={p.contact.location} colorVar="var(--text)" intensity={11} /></li>
  </ul>
</section>

<script>
  // Projects section controller: category filter × view mode (list|card) ×
  // paging. List view paginates (6/page); card view shows 6 and grows by 6 via
  // a "more" button. Changing filter or view resets paging.
  const section = document.getElementById('projects');
  if (section) {
    const pills = [...section.querySelectorAll<HTMLButtonElement>('.filter__pill')];
    const viewBtns = [...section.querySelectorAll<HTMLButtonElement>('.view-toggle button')];
    const list = section.querySelector<HTMLElement>('.project-list')!;
    const cards = [...section.querySelectorAll<HTMLElement>('.project-card[data-categories]')];
    const moreWrap = section.querySelector<HTMLElement>('.projects-more')!;
    const moreBtn = section.querySelector<HTMLButtonElement>('.btn-more')!;
    const pager = section.querySelector<HTMLElement>('.projects-pager')!;
    const PAGE = parseInt(list.dataset.pageSize || '6', 10);

    let view: 'list' | 'card' = 'list';
    let category = 'all';
    let page = 0; // list mode
    let shown = PAGE; // card mode

    const filtered = () =>
      cards.filter((c) => category === 'all' || (c.dataset.categories || '').split(' ').includes(category));

    const buildPager = (pages: number) => {
      pager.innerHTML = '';
      pager.hidden = pages <= 1;
      if (pages <= 1) return;
      const mk = (label: string, target: number, opts: { active?: boolean; disabled?: boolean } = {}) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.textContent = label;
        if (opts.active) b.classList.add('is-active');
        if (opts.disabled) b.disabled = true;
        b.addEventListener('click', () => {
          page = target;
          render();
          list.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        pager.appendChild(b);
      };
      mk('‹', Math.max(0, page - 1), { disabled: page === 0 });
      for (let i = 0; i < pages; i++) mk(String(i + 1), i, { active: i === page });
      mk('›', Math.min(pages - 1, page + 1), { disabled: page === pages - 1 });
    };

    function render() {
      const set = filtered();
      list.classList.toggle('is-list', view === 'list');
      list.classList.toggle('is-card', view === 'card');
      let visible: HTMLElement[];
      if (view === 'list') {
        const pages = Math.max(1, Math.ceil(set.length / PAGE));
        if (page >= pages) page = pages - 1;
        visible = set.slice(page * PAGE, page * PAGE + PAGE);
        moreWrap.hidden = true;
        buildPager(pages);
      } else {
        if (shown > set.length) shown = Math.max(PAGE, Math.ceil(set.length / PAGE) * PAGE);
        visible = set.slice(0, shown);
        pager.hidden = true;
        pager.innerHTML = '';
        moreWrap.hidden = shown >= set.length;
      }
      const showSet = new Set(visible);
      cards.forEach((c) => {
        const on = showSet.has(c);
        c.hidden = !on;
        // force-reveal shown cards so paged-in ones are never left at opacity:0
        if (on) c.classList.add('is-visible');
      });
    }

    pills.forEach((pill) =>
      pill.addEventListener('click', () => {
        category = pill.dataset.filter || 'all';
        page = 0;
        shown = PAGE;
        pills.forEach((b) => b.classList.toggle('is-active', b === pill));
        render();
      })
    );
    viewBtns.forEach((btn) =>
      btn.addEventListener('click', () => {
        view = (btn.dataset.view as 'list' | 'card') || 'list';
        page = 0;
        shown = PAGE;
        viewBtns.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-pressed', String(on));
        });
        render();
      })
    );
    moreBtn.addEventListener('click', () => {
      shown += PAGE;
      render();
    });

    render();
  }
</script>

<style>
  .hero {
    position: relative;
    padding: 4.5rem 0 3.5rem;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }
  /* keep hero content above the KineticGrid canvas background */
  .hero > h1,
  .hero > .hero__tagline,
  .hero > .hero__cta {
    position: relative;
    z-index: 1;
  }
  .hero h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .hero__tagline {
    margin: 0;
    opacity: 0.85;
    max-width: 42rem;
    font-size: 1.15rem;
    line-height: 1.7;
  }
  .hero__cta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-top: 1.75rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    font-weight: 600;
    transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn--primary {
    padding: 0.6rem 1.4rem;
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    font-size: 0.95rem;
  }
  .btn--primary:hover {
    filter: brightness(1.08);
  }
  .btn--icon {
    width: 2.6rem;
    height: 2.6rem;
    padding: 0;
  }
  .btn--icon :global(svg) {
    width: 1.25rem;
    height: 1.25rem;
  }
  .btn--icon:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .section {
    padding: 3.5rem 0 0.5rem;
    scroll-margin-top: 4.5rem;
  }
  .section > h2 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1.75rem;
    color: var(--accent);
  }
  .section > h2::before {
    content: '';
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--accent);
  }
  .about__para {
    margin: 0 0 1rem;
    max-width: 46rem;
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .skills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .skill {
    padding: 1.25rem 1.35rem;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .skill:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
    border-color: var(--border-strong);
  }
  .skill__icon {
    display: inline-flex;
    width: 2.6rem;
    height: 2.6rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.7rem;
    background: var(--fill-softer);
    border: 1px solid var(--border-soft);
    margin-bottom: 0.8rem;
    color: var(--text-muted);
    transition: color 0.25s ease, background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }
  .skill__icon :global(svg) {
    width: 1.4rem;
    height: 1.4rem;
  }
  /* Hover: outline icon "fills in" with the accent treatment. */
  .skill:hover .skill__icon {
    color: var(--accent);
    background: var(--accent-soft);
    border-color: var(--accent);
    transform: scale(1.08) rotate(-3deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .skill,
    .skill__icon {
      transition: none;
    }
    .skill:hover {
      transform: none;
    }
    .skill:hover .skill__icon {
      transform: none;
    }
  }
  .skill__name {
    display: block;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .skill__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .exp,
  .edu {
    list-style: none;
    margin: 0;
    padding: 0 0 0 1.25rem;
    display: grid;
    gap: 1.75rem;
    border-left: 2px solid var(--border-soft);
  }
  .exp__item,
  .edu__item {
    position: relative;
  }
  .exp__item::before,
  .edu__item::before {
    content: '';
    position: absolute;
    left: -1.56rem;
    top: 0.3rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--accent);
  }
  .exp__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .exp__role {
    font-weight: 700;
  }
  .exp__period {
    font-size: 0.85rem;
    opacity: 0.65;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .exp__org {
    opacity: 0.8;
    margin-top: 0.15rem;
  }
  .exp__summary {
    margin: 0.5rem 0 0.25rem;
    opacity: 0.85;
    font-size: 0.92rem;
  }
  /* Custom accent bullets: `display:grid` on a UL suppresses native ::marker
     rendering in some engines — the 1440px "no bullets" bug — so draw our own. */
  .exp__highlights {
    list-style: none;
    margin: 0.5rem 0 0;
    padding-left: 0;
    display: grid;
    gap: 0.3rem;
  }
  .exp__highlights li {
    font-size: 0.92rem;
    position: relative;
    padding-left: 1.1rem;
  }
  .exp__highlights li::before {
    content: '';
    position: absolute;
    left: 0.15rem;
    top: 0.55em;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.75;
  }

  /* Projects toolbar: filter on the left, list/card view toggle on the right.
     Wraps on narrow screens so the toggle stays visible on mobile too. */
  .projects-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }
  .view-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    background: var(--fill-softer);
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    flex-shrink: 0;
  }
  .view-toggle button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 1.9rem;
    border: none;
    background: transparent;
    color: var(--text-muted);
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .view-toggle button svg {
    width: 1.05rem;
    height: 1.05rem;
  }
  .view-toggle button:hover {
    color: var(--text);
  }
  .view-toggle button.is-active {
    color: #fff;
    background: var(--accent);
  }
  .view-toggle button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Segmented control: one inset track holding all pills, with a single
     sliding accent "thumb" behind the active one — reads as a considered
     control rather than a row of loose chips. */
  .filter {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.15rem;
    padding: 0.3rem;
    background: var(--fill-softer);
