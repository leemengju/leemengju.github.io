---
/**
 * One listing card, shared by the zh and en home pages so the two locales
 * can't drift apart visually. Locale only affects link targets and which
 * generated cover is used.
 */
import TagRow from './TagRow.astro';
import { coverUrl, type ProjectEntry } from '../lib/projects';
import { projectPath, type Locale } from '../lib/i18n';

interface Props {
  project: ProjectEntry;
  locale?: Locale;
}
const { project, locale = 'zh' } = Astro.props as Props;
---

<li class="project-card" data-reveal>
  <a href={projectPath(project.id, locale)}>
    <img class="project-card__cover" src={coverUrl(project, locale)} alt="" loading="lazy" />
    <div class="project-card__body">
      <span class="project-card__title">{project.data.title}</span>
      <span class="project-card__meta">
        {project.data.role} · {project.data.period}
      </span>
      {project.data.metrics && <span class="project-card__metrics">{project.data.metrics}</span>}
      <TagRow tags={project.data.tags} />
    </div>
  </a>
</li>

<style>
  .project-card {
    height: 100%;
  }
  .project-card a {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .project-card a:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
    border-color: var(--border-strong);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card a {
      transition: none;
    }
    .project-card a:hover {
      transform: none;
    }
  }
  .project-card__cover {
    display: block;
    width: 100%;
    aspect-ratio: 1200 / 630;
    object-fit: cover;
    background: var(--fill-softer);
    border-bottom: 1px solid var(--border-soft);
  }
  .project-card__body {
    padding: 1.25rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .project-card__title {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.4;
  }
  .project-card__meta {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 0.35rem;
  }
  .project-card__metrics {
    display: block;
    margin-top: 0.6rem;
    font-weight: 600;
    color: var(--accent);
    font-size: 0.92rem;
  }
  .project-card :global(.tag-row) {
    margin-top: auto;
    padding-top: 0.9rem;
  }
</style>
