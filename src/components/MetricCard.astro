---
/**
 * Prominent headline-metric display, e.g. "整月查詢 約104s → 約5s(~21×)".
 * Deliberately renders the metrics string as-is rather than parsing it into
 * separate before/after values — the string is free-text, often bilingual /
 * annotated, and reliable parsing isn't worth the fragility. For a to-scale
 * numeric comparison, pair this with BeforeAfterBar (uses a separate,
 * structured `beforeAfter` frontmatter field).
 */
interface Props {
  metric: string;
}
const { metric } = Astro.props as Props;
---

<p class="metric-card" data-reveal>{metric}</p>

<style>
  .metric-card {
    display: inline-block;
    margin: 0;
    padding: 0.6rem 1rem;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    background: var(--fill-soft);
  }
</style>
