---
/**
 * Section navigation with scrollspy (IntersectionObserver highlights the
 * section in view). Generic over `items`, so it serves both the home page
 * and project-article TOCs.
 *
 * Two layouts:
 *  - ≥1161px: fixed right-edge dot rail; labels fly out to the left on hover.
 *  - ≤1160px: a pinned top-right hamburger button; tap opens a dropdown panel
 *    of section links (closes on select / outside click / Escape).
 */
import ChapterRail from './effects/ChapterRail.tsx';

interface NavItem {
  id: string;
  label: string;
}
interface Props {
  items: NavItem[];
}
const { items } = Astro.props as Props;
---

<nav class="floating-nav" aria-label="Section navigation">
  {/* Desktop: magnifying chapter rail (item 5). Own scrollspy + scroll-on-select. */}
  <div class="floating-nav__rail">
    <ChapterRail client:visible items={items} />
  </div>

  {/* Mobile hamburger + dropdown */}
  <div class="floating-nav__mobile">
    <button
      type="button"
      class="floating-nav__toggle"
      aria-label="Sections menu"
      aria-expanded="false"
      aria-controls="floating-nav-menu"
    >
      <span></span><span></span><span></span>
    </button>
    <ul class="floating-nav__menu" id="floating-nav-menu" hidden>
      {
        items.map((item) => (
          <li>
            <a href={`#${item.id}`} data-nav-link={item.id}>{item.label}</a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  // One .floating-nav per page (home OR a project article, never both).
  const root = document.querySelector<HTMLElement>('.floating-nav');
  if (root) {
    const links = root.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');
    const toggle = root.querySelector<HTMLButtonElement>('.floating-nav__toggle');
    const menu = root.querySelector<HTMLUListElement>('.floating-nav__menu');

    // Scrollspy — highlight active section across BOTH rail and menu.
    const ids = [...new Set([...links].map((l) => l.dataset.navLink!))];
    const sections = ids.map((id) => document.getElementById(id)).filter((el): el is HTMLElement => !!el);
    const setActive = (id: string) =>
      links.forEach((l) => l.classList.toggle('is-active', l.dataset.navLink === id));
    if (sections.length) {
      const obs = new IntersectionObserver(
        (entries) => {
          const vis = entries.filter((e) => e.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (vis) setActive(vis.target.id);
        },
        { rootMargin: '-35% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] }
      );
      sections.forEach((el) => obs.observe(el));
    }

    // Mobile dropdown open/close.
    if (toggle && menu) {
      const setOpen = (open: boolean) => {
        toggle.setAttribute('aria-expanded', String(open));
        menu.hidden = !open;
        root.classList.toggle('is-open', open);
      };
      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        setOpen(menu.hidden);
      });
      menu.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) setOpen(false);
      });
      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) setOpen(false);
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') setOpen(false);
      });
    }
  }
</script>

<style>
  /* ---------- Desktop (≥1161px): fixed right chapter rail ---------- */
  .floating-nav {
    position: fixed;
    right: 1.4rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: var(--z-nav, 40);
  }
  .floating-nav__mobile {
    display: none;
  }
  /* wrapper for the ChapterRail island (styles itself); hidden on mobile */
  .floating-nav__rail {
    display: block;
  }

  /* ---------- ≤1160px: pinned top-right hamburger + dropdown ---------- */
  @media (max-width: 1160px) {
    .floating-nav {
      position: fixed;
      top: 0.85rem;
      right: 0.85rem;
      left: auto;
      transform: none;
    }
    .floating-nav__rail {
      display: none;
    }
    .floating-nav__mobile {
      display: block;
      position: relative;
    }
    .floating-nav__toggle {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 4px;
      width: 2.6rem;
      height: 2.6rem;
      padding: 0 0.7rem;
      border: 1px solid var(--border-soft);
      border-radius: 0.7rem;
      background: color-mix(in srgb, var(--surface) 85%, transparent);
      backdrop-filter: blur(8px);
      cursor: pointer;
    }
    .floating-nav__toggle span {
      display: block;
      height: 2px;
      width: 100%;
      background: currentColor;
      border-radius: 2px;
      transition: transform 0.25s ease, opacity 0.2s ease;
    }
    .floating-nav.is-open .floating-nav__toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }
    .floating-nav.is-open .floating-nav__toggle span:nth-child(2) {
      opacity: 0;
    }
    .floating-nav.is-open .floating-nav__toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
    .floating-nav__menu {
      position: absolute;
      top: calc(100% + 0.5rem);
      right: 0;
      min-width: 11rem;
      list-style: none;
      margin: 0;
      padding: 0.4rem;
      display: grid;
      gap: 0.1rem;
      background: var(--surface);
      border: 1px solid var(--border-soft);
      border-radius: 0.85rem;
      box-shadow: var(--shadow-hover);
    }
    .floating-nav__menu a {
      display: block;
      padding: 0.55rem 0.85rem;
      border-radius: 0.55rem;
      text-decoration: none;
      color: inherit;
      font-size: 0.9rem;
      font-weight: 600;
    }
    .floating-nav__menu a:hover {
      background: var(--fill-soft);
    }
    .floating-nav__menu a.is-active {
      color: var(--accent);
      background: var(--accent-soft);
    }
  }
</style>
