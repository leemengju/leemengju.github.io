---
import '../styles/tokens.css';
import '../styles/code-blocks.css';
import DiagramBlock from '../components/DiagramBlock.astro';
import RevealScript from '../components/RevealScript.astro';
import BackToTop from '../components/BackToTop.astro';
import CursorArc from '../components/CursorArc.astro';
import { strings, localeFromPath, alternatePath, homePath } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description, ogImage } = Astro.props as Props;

// Locale is derived from the URL (en pages live under /en/), so pages don't
// have to thread a locale prop through the layout. Slugs are identical across
// locales, making the language switcher a pure path transform.
const locale = localeFromPath(Astro.url.pathname);
const t = strings[locale];
const altPath = alternatePath(Astro.url.pathname);
const altLangAttr = strings[locale === 'en' ? 'zh' : 'en'].langAttr;
---

<html lang={t.langAttr}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}
    <link rel="alternate" hreflang={t.langAttr} href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="alternate" hreflang={altLangAttr} href={new URL(altPath, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(locale === 'en' ? altPath : Astro.url.pathname, Astro.site)} />
  </head>
  <body>
    <header class="site-header">
      <a class="site-header__brand" href={homePath(locale)}>
        <img class="site-header__logo" src="/logo.svg" alt="" width="28" height="28" />
        <span>{t.brand}</span>
      </a>
      <a class="site-header__lang" href={altPath} aria-label={t.switcherAria}>{t.switcherLabel}</a>
    </header>
    <main>
      <slot />
    </main>
    <RevealScript />
    <DiagramBlock />
    <BackToTop />
    <CursorArc />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
  }
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
  }
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: inherit;
  }
  .site-header__logo {
    display: block;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 6px;
  }
  .site-header__lang {
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    opacity: 0.75;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    transition: opacity 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }
  .site-header__lang:hover {
    opacity: 1;
    background: var(--fill-soft);
    border-color: var(--border-strong);
  }
  main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  /* Shared card surface used by project/skill/stat cards + article header. */
  .card,
  .u-card {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  /* Motion tier L0: default reveal-on-scroll, no framework (src script below). */
  [data-reveal] {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
