---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectArticle from '../../components/ProjectArticle.astro';
import { coverUrl } from '../../lib/projects';
import { strings } from '../../lib/i18n';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.data.title}${strings.zh.titleSuffix}`} ogImage={coverUrl(project, 'zh')}>
  <ProjectArticle project={project} locale="zh" />
</BaseLayout>
